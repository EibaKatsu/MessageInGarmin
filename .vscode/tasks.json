{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Monkey C: Build Training",
      "type": "process",
      "command": "java",
      "args": [
        "-Xms1g",
        "-Dfile.encoding=UTF-8",
        "-Dapple.awt.UIElement=true",
        "-jar",
        "${env:CONNECTIQ_HOME}/bin/monkeybrains.jar",
        "-o",
        "bin/grow.prg",
        "-f",
        "${workspaceFolder}/monkey.jungle;${workspaceFolder}/monkey.training.jungle",
        "-y",
        "${workspaceFolder}/.vscode/developer_key",
        "-d",
        "fr255_sim",
        "-w"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Monkey C: Build Race",
      "type": "process",
      "command": "java",
      "args": [
        "-Xms1g",
        "-Dfile.encoding=UTF-8",
        "-Dapple.awt.UIElement=true",
        "-jar",
        "${env:CONNECTIQ_HOME}/bin/monkeybrains.jar",
        "-o",
        "bin/grow.prg",
        "-f",
        "${workspaceFolder}/monkey.jungle;${workspaceFolder}/monkey.race.jungle",
        "-y",
        "${workspaceFolder}/.vscode/developer_key",
        "-d",
        "fr255_sim",
        "-w"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Monkey C: Build Screenshot",
      "type": "process",
      "command": "java",
      "args": [
        "-Xms1g",
        "-Dfile.encoding=UTF-8",
        "-Dapple.awt.UIElement=true",
        "-jar",
        "${env:CONNECTIQ_HOME}/bin/monkeybrains.jar",
        "-o",
        "bin/grow.prg",
        "-f",
        "${workspaceFolder}/monkey.jungle;${workspaceFolder}/monkey.screenshot.jungle",
        "-y",
        "${workspaceFolder}/.vscode/developer_key",
        "-d",
        "fr255_sim",
        "-w"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Monkey C: Run Current PRG",
      "type": "process",
      "command": "${workspaceFolder}/scripts/run_prg_with_retry.sh",
      "args": [
        "bin/grow.prg",
        "fr255"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "CIQ_INTERACTIVE_MODE": "0",
          "CIQ_OPEN_SIMULATOR": "1"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Monkey C: Run Current PRG (Auto Retry)",
      "type": "process",
      "command": "${workspaceFolder}/scripts/run_prg_with_retry.sh",
      "args": [
        "bin/grow.prg",
        "fr255"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "CIQ_INTERACTIVE_MODE": "0",
          "CIQ_OPEN_SIMULATOR": "1"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Monkey C: Run Current PRG (Interactive)",
      "type": "process",
      "command": "${workspaceFolder}/scripts/run_prg_with_retry.sh",
      "args": [
        "bin/grow.prg",
        "fr255"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "CIQ_INTERACTIVE_MODE": "1",
          "CIQ_OPEN_SIMULATOR": "0"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Monkey C: Build+Run Training",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Monkey C: Build Training",
        "Monkey C: Run Current PRG"
      ],
      "problemMatcher": []
    },
    {
      "label": "Monkey C: Build+Run Race",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Monkey C: Build Race",
        "Monkey C: Run Current PRG"
      ],
      "problemMatcher": []
    },
    {
      "label": "Monkey C: Build+Run Screenshot",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Monkey C: Build Screenshot",
        "Monkey C: Run Current PRG"
      ],
      "problemMatcher": []
    }
  ]
}
